    id INTEGER PRIMARY KEY AUTOINCREMENT,
    flat_number TEXT NOT NULL,
    month_year TEXT NOT NULL,
    amount_due REAL NOT NULL,
    amount_paid REAL DEFAULT 0,
    due_date DATE,
    paid_date DATE,
    status TEXT DEFAULT 'pending', resident_flat TEXT, resident_name TEXT, amount REAL, payment_date TEXT, transaction_id TEXT,
    FOREIGN KEY (flat_number) REFERENCES residents (flat_number)
) j !! tablecomplaintscomplaints	CREATE TABLE complaints (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    resident_flat TEXT NOT NULL,
    subject TEXT NOT NULL,
    description TEXT,
    date_submitted DATE NOT NULL,
    status TEXT DEFAULT 'open',
    resolution TEXT,
    resolved_date DATE,
    FOREIGN KEY (resident_flat) REFERENCES residents (flat_number)
) @   WtablenoticesnoticesCREATE TABLE notices (
